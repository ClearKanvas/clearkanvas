# Contact form delivery (app/api/contact/route.ts)
# Copy to .env.local and fill in to enable real email sending via Resend.
# Without RESEND_API_KEY, submissions are logged to the server console instead.

RESEND_API_KEY=
# Where enquiries are delivered (defaults to hello@clearkanvas.com)
CONTACT_TO_EMAIL=hello@clearkanvas.com
# Must be a Resend-verified sender (defaults to onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=ClearKanvas <onboarding@resend.dev>
